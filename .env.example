# WalnutEverMem Configuration Example
# Copy this file to .env and modify as needed

# Database Configuration
# Backend: sqlite (default, zero-config) or postgresql
WALNUT_DB__BACKEND=sqlite
WALNUT_DB__SQLITE_PATH=walnut_memory.db

# PostgreSQL Configuration (only needed if backend=postgresql)
# WALNUT_DB__HOST=localhost
# WALNUT_DB__PORT=5432
# WALNUT_DB__DATABASE=walnut_memory
# WALNUT_DB__USER=postgres
# WALNUT_DB__PASSWORD=your_password_here

# Embedding Configuration
# Dimension must match your embedding model:
# - OpenAI text-embedding-3-small: 1536
# - OpenAI text-embedding-3-large: 3072
# - Cohere embed-v3: 1024
WALNUT_EMBED__DIMENSION=1536
WALNUT_EMBED__PROVIDER=openai
WALNUT_EMBED__MODEL_NAME=text-embedding-3-small
WALNUT_EMBED__API_KEY=your_api_key_here

# Retrieval Configuration
WALNUT_RETRIEVE__SIMILARITY_THRESHOLD=0.7
WALNUT_RETRIEVE__MAX_POINTERS_PER_NODE=100

# Debug Mode
WALNUT_DEBUG=false
