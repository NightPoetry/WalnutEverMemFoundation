{
  "name": "walnut-ever-mem",
  "version": "0.1.0",
  "description": "A binary-logic based infinite context memory foundation for LLMs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "walnut-init": "./dist/cli/init.js",
    "walnut-server": "./dist/cli/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "cli:init": "ts-node src/cli/init.ts",
    "cli:server": "ts-node src/cli/server.ts"
  },
  "keywords": [
    "llm",
    "memory",
    "context",
    "ai",
    "embedding"
  ],
  "author": "NightPoetry",
  "license": "Apache-2.0",
  "dependencies": {
    "better-sqlite3": "^9.4",
    "pg": "^8.11",
    "zod": "^3.22",
    "dotenv": "^16.4",
    "express": "^4.18",
    "cors": "^2.8",
    "commander": "^12.0",
    "inquirer": "^9.2",
    "chalk": "^4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6",
    "@types/express": "^4.17",
    "@types/cors": "^2.8",
    "@types/inquirer": "^9.0",
    "@types/node": "^20.11",
    "@types/pg": "^8.10",
    "typescript": "^5.3",
    "ts-node": "^10.9",
    "jest": "^29.7",
    "@types/jest": "^29.5",
    "ts-jest": "^29.1",
    "eslint": "^8.56",
    "@typescript-eslint/eslint-plugin": "^6.19",
    "@typescript-eslint/parser": "^6.19"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
